# Bun (分) Environment Variables
# Copy to .env.local and fill in values

# === Stellar Network ===
# Soroban RPC endpoint (defaults to testnet)
STELLAR_RPC=https://soroban-testnet.stellar.org
# Horizon API endpoint
STELLAR_HORIZON=https://horizon-testnet.stellar.org
# Agent secret key (Stellar S... format)
AGENT_SECRET=

# === Privy Auth (Email OTP) ===
# Get these from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# === MongoDB (User mapping) ===
# privyUserId -> partyId mapping
MONGODB_URI=

# === Soroban Contracts ===
# Set after deploying contracts to testnet
ESCROW_CONTRACT_ID=
ZK_VERIFIER_CONTRACT_ID=
